import React, { useEffect, useState } from 'react';

export default function AdminFollowUps() {
  const [items, setItems] = useState([]);
  const [alunoId, setAlunoId] = useState('');
  const [atividadeId, setAtividadeId] = useState('');
  const [realizado, setRealizado] = useState('');
  const [dateFrom, setDateFrom] = useState('');
  const [dateTo, setDateTo] = useState('');

  async function fetchItems() {
    const params = new URLSearchParams();
    if (alunoId) params.append('aluno_id', alunoId);
    if (atividadeId) params.append('atividade_id', atividadeId);
    if (realizado) params.append('realizado', realizado);
    if (dateFrom) params.append('date_from', dateFrom);
    if (dateTo) params.append('date_to', dateTo);
    const res = await fetch('/api/admin/followups?' + params.toString(), { headers: { 'Content-Type': 'application/json', 'X-ADMIN': '1' }});
    const js = await res.json();
    setItems(js.items || []);
  }

  useEffect(() => { fetchItems(); }, []);

  async function handleExport() {
    const params = new URLSearchParams();
    if (alunoId) params.append('aluno_id', alunoId);
    if (atividadeId) params.append('atividade_id', atividadeId);
    if (realizado) params.append('realizado', realizado);
    if (dateFrom) params.append('date_from', dateFrom);
    if (dateTo) params.append('date_to', dateTo);

    const res = await fetch('/api/admin/followups/export?' + params.toString(), {
      headers: { 'X-ADMIN': '1' }
    });
    const blob = await res.blob();
    const url = window.URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'followups.csv';
    a.click();
  }

  return (
    <div>
      <h2>Admin - FollowUps</h2>
      <div>
        <input placeholder="Aluno ID" value={alunoId} onChange={e=>setAlunoId(e.target.value)} />
        <input placeholder="Atividade ID" value={atividadeId} onChange={e=>setAtividadeId(e.target.value)} />
        <select value={realizado} onChange={e=>setRealizado(e.target.value)}>
          <option value="">Todos</option>
          <option value="true">Realizado</option>
          <option value="false">Não realizado</option>
        </select>
        <input type="date" value={dateFrom} onChange={e=>setDateFrom(e.target.value)} />
        <input type="date" value={dateTo} onChange={e=>setDateTo(e.target.value)} />
        <button onClick={fetchItems}>Filtrar</button>
        <button onClick={handleExport}>Exportar CSV</button>
      </div>

      <table>
        <thead>
          <tr><th>ID</th><th>Aluno</th><th>Atividade</th><th>Data</th><th>Realizado</th><th>Revisado</th><th>Ações</th></tr>
        </thead>
        <tbody>
          {items.map(it => (
            <tr key={it.id}>
              <td>{it.id}</td>
              <td>{it.aluno_nome} ({it.aluno_id})</td>
              <td>{it.atividade_texto || it.atividade_id}</td>
              <td>{it.data_realizacao}</td>
              <td>{it.realizado ? 'Sim' : 'Não'}</td>
              <td>{it.revisado ? 'Sim' : 'Não'}</td>
              <td>
                <button onClick={async ()=>{ await fetch(`/api/admin/followups/${it.id}`, { method: 'DELETE', headers: { 'X-ADMIN': '1' }}); fetchItems(); }}>Apagar</button>
                <button onClick={async ()=>{ await fetch(`/api/admin/followups/${it.id}/revisar`, { method: 'PUT', headers: { 'X-ADMIN': '1' }}); fetchItems(); }}>Marcar revisado</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  );
}
