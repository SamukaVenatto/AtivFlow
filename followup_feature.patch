import React, { useState, useEffect } from 'react';

export default function StudentFollowUp() {
  const [atividadeId, setAtividadeId] = useState('');
  const [atividadeTexto, setAtividadeTexto] = useState('');
  const [dataRealizacao, setDataRealizacao] = useState(new Date().toISOString().slice(0,10));
  const [funcao, setFuncao] = useState('');
  const [realizado, setRealizado] = useState(true);
  const [justificativa, setJustificativa] = useState('');
  const [historico, setHistorico] = useState([]);
  const [page, setPage] = useState(1);

  const API_BASE = '/api';

  async function fetchHistorico() {
    const res = await fetch(`${API_BASE}/followups/me?page=${page}&per_page=20`, { headers: { 'Content-Type': 'application/json' }});
    const js = await res.json();
    setHistorico(js.items || []);
  }

  useEffect(() => { fetchHistorico(); }, [page]);

  async function handleSubmit(e) {
    e.preventDefault();
    if (!realizado && (!justificativa || justificativa.trim()==='')) {
      alert('Justificativa obrigatória quando não realizado.');
      return;
    }
    const payload = {
      atividade_id: atividadeId || null,
      atividade_texto: atividadeTexto,
      data_realizacao: dataRealizacao,
      funcao: funcao,
      realizado: realizado,
      justificativa: justificativa
    };
    const res = await fetch('/api/followups', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)});
    if (res.ok) {
      alert('Enviado com sucesso');
      setAtividadeId('');
      setAtividadeTexto('');
      setFuncao('');
      setRealizado(true);
      setJustificativa('');
      fetchHistorico();
    } else {
      const txt = await res.json();
      alert('Erro: ' + (txt.error || JSON.stringify(txt)));
    }
  }

  return (
    <div>
      <h2>Follow Up - Preenchimento Individual</h2>
      <form onSubmit={handleSubmit}>
        <div>
          <label>Atividade (ID opcional)</label>
          <input value={atividadeId} onChange={e => setAtividadeId(e.target.value)} placeholder="ID da atividade (opcional)"/>
        </div>
        <div>
          <label>Atividade realizada (texto)</label>
          <input value={atividadeTexto} onChange={e => setAtividadeTexto(e.target.value)} maxLength={1000} />
        </div>
        <div>
          <label>Data de realização</label>
          <input type="date" value={dataRealizacao} onChange={e => setDataRealizacao(e.target.value)} />
        </div>
        <div>
          <label>Função / Responsabilidade</label>
          <input value={funcao} onChange={e => setFuncao(e.target.value)} maxLength={1000} />
        </div>
        <div>
          <label>Realizado</label>
          <select value={realizado ? 'sim' : 'nao'} onChange={e => setRealizado(e.target.value === 'sim')}>
            <option value="sim">Sim</option>
            <option value="nao">Não</option>
          </select>
        </div>
        {!realizado && (
          <div>
            <label>Justificativa</label>
            <textarea value={justificativa} onChange={e => setJustificativa(e.target.value)} maxLength={1000} />
          </div>
        )}
        <button type="submit">ENVIAR ATIVIDADE</button>
      </form>

      <h3>Histórico</h3>
      <table>
        <thead>
          <tr>
            <th>Data</th><th>Atividade</th><th>Função</th><th>Realizado</th><th>Justificativa</th>
          </tr>
        </thead>
        <tbody>
          {historico.map(h => (
            <tr key={h.id}>
              <td>{h.data_realizacao}</td>
              <td>{h.atividade_texto || h.atividade_id}</td>
              <td>{h.funcao}</td>
              <td>{h.realizado ? 'Sim' : 'Não'}</td>
              <td>{h.justificativa}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  );
}
